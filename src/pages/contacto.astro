---
import Layout from "@/layouts/Layout.astro"
---
<Layout title="Contacto">
    <section class="contact-section">
        <div class="container contact-container">
            <div class="contact-intro">
                <p class="eyebrow">Contacto</p>
                <h1>Conversemos sobre tu proyecto</h1>
                <p>
                    Completa el formulario y cuéntanos qué necesitas. Te responderemos a la brevedad para coordinar tu solicitud.
                </p>
            </div>

            <form class="contact-form" action="mailto:taurocco@gmail.com" method="post" enctype="text/plain">
                <div class="form-field">
                    <label for="name">Nombre</label>
                    <input id="name" name="Nombre" type="text" placeholder="Tu nombre" autocomplete="name" required />
                </div>

                <div class="form-field">
                    <label for="email">Correo electrónico</label>
                    <input id="email" name="Correo" type="email" placeholder="tu@email.com" autocomplete="email" required />
                </div>

                <div class="form-field">
                    <label for="phone">Teléfono</label>
                    <input id="phone" name="Telefono" type="tel" placeholder="+56 9 1234 5678" autocomplete="tel" />
                </div>

                <div class="form-field">
                    <label for="subject">Asunto</label>
                    <input id="subject" name="Asunto" type="text" placeholder="¿En qué podemos ayudarte?" required />
                </div>

                <div class="form-field full-width">
                    <label for="message">Mensaje</label>
                    <textarea id="message" name="Mensaje" rows="6" placeholder="Cuéntanos los detalles de tu solicitud" required></textarea>
                </div>

                <button type="submit">Enviar mensaje</button>
            </form>
        </div>
    </section>
</Layout>

<style>
    .contact-section {
        padding: 64px 20px;
    }

    .contact-container {
        display: grid;
        gap: 32px;
    }

    .contact-intro {
        max-width: 620px;
    }

    .eyebrow {
        color: var(--orange);
        font-size: 0.875rem;
        font-weight: 700;
        letter-spacing: 0.08em;
        margin-bottom: 12px;
        text-transform: uppercase;
    }

    h1 {
        color: var(--black);
        font-size: clamp(2rem, 5vw, 3.5rem);
        line-height: 1.1;
        margin-bottom: 16px;
    }

    .contact-intro p:not(.eyebrow) {
        color: #475569;
        font-size: 1.125rem;
        line-height: 1.7;
    }

    .contact-form {
        background: var(--white);
        border-radius: 24px;
        box-shadow: 0 20px 45px rgba(15, 23, 42, 0.08);
        display: grid;
        gap: 20px;
        padding: 28px;
    }

    .form-field {
        display: grid;
        gap: 8px;
    }

    label {
        color: var(--black);
        font-weight: 700;
    }

    input,
    textarea {
        border: 1px solid #d8e0e8;
        border-radius: 14px;
        color: var(--black);
        font: inherit;
        padding: 14px 16px;
        width: 100%;
    }

    input:focus,
    textarea:focus {
        border-color: var(--turquoise);
        box-shadow: 0 0 0 4px rgba(0, 153, 168, 0.14);
        outline: none;
    }

    textarea {
        resize: vertical;
    }

    button {
        background: var(--orange);
        border: 0;
        border-radius: 999px;
        color: var(--white);
        cursor: pointer;
        font: inherit;
        font-weight: 700;
        padding: 16px 24px;
        transition: transform 160ms ease, box-shadow 160ms ease;
    }

    button:hover,
    button:focus-visible {
        box-shadow: 0 12px 24px rgba(255, 95, 0, 0.25);
        transform: translateY(-2px);
    }

    @media (min-width: 768px) {
        .contact-container {
            grid-template-columns: 0.85fr 1.15fr;
            align-items: start;
        }

        .contact-form {
            grid-template-columns: repeat(2, minmax(0, 1fr));
            padding: 36px;
        }

        .full-width,
        button {
            grid-column: 1 / -1;
        }

        button {
            justify-self: start;
        }
    }
</style>
