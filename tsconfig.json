{
  "extends": "astro/tsconfigs/strict",
  "include": [".astro/types.d.ts", "**/*"],
  "exclude": ["dist"],
  "compilerOptions": {
    "paths": {
      "@/*":["./src/*"]
    },
    "jsx": "preserve", // Importante: Astro maneja la transformación, no el compilador de TS
    "jsxImportSource": "astro" // Solo si usas exclusivamente Astro
  }
}
